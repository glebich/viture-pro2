{
  "headers": [
    {
      "source": "/assets/:file(index-[A-Za-z0-9_]+\\.(?:js|css)|[A-Za-z0-9_]+-[A-Za-z0-9_]{8}\\.(?:js|css))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/:file*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=2592000, stale-while-revalidate=86400"
        }
      ]
    }
  ]
}
